<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE"/>
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
        tools:ignore="ProtectedPermissions"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage"/>

    <application
        android:name="com.huajun.music.app.HuaJunApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_logo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.HuaJunMusic"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <activity
            android:name="com.huajun.music.ui.activity.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.HuaJunMusic">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity
            android:name="com.huajun.music.ui.activity.PlayerActivity"
            android:exported="false"
            android:theme="@style/Theme.HuaJunMusic.Player"/>

        <activity
            android:name="com.huajun.music.ui.activity.PlaylistDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.HuaJunMusic"/>

        <activity
            android:name="com.huajun.music.ui.activity.SearchActivity"
            android:exported="false"
            android:theme="@style/Theme.HuaJunMusic"/>

        <activity
            android:name="com.huajun.music.ui.activity.ApiSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.HuaJunMusic"
            android:label="API设置"/>

        <service
            android:name="com.huajun.music.service.MusicService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback"/>

    </application>

</manifest>
