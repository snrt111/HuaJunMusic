<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" /> <!-- 设置背景色 -->
            <corners android:radius="8dp" /> <!-- 圆角半径 -->
        </shape>
    </item>
    <!-- 边框宽度 -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <!-- 边框宽度 -->
        <!-- 边框颜色 -->
        <shape android:shape="rectangle">
            <stroke
                android:width="2dp"
                android:color="#000000" />
            <corners android:radius="8dp" /> <!-- 圆角半径 -->
        </shape>
    </item>
</layer-list>
