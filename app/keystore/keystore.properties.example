# ============================================
# 华军音乐 - 签名配置文件模板
# ============================================
# 使用说明：
# 1. 复制此文件为 keystore.properties（不要提交到Git）
# 2. 填写你的签名信息
# 3. 将release.keystore放在app/keystore/目录下

# Keystore文件路径（相对于app/目录）
STORE_FILE=keystore/release.keystore

# Keystore密码
STORE_PASSWORD=your_keystore_password_here

# 密钥别名
KEY_ALIAS=your_key_alias_here

# 密钥密码
KEY_PASSWORD=your_key_password_here
